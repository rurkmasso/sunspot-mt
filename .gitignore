# Sunspot site — gitignore
.DS_Store
*.log
.vscode/
.idea/
node_modules/
.env
.env.*

# Build artifacts (none yet, but reserved)
dist/
build/

# Local-only screenshots and tmp
/tmp-screenshots/
*.tmp.*

# Photo-fetch cache (rebuilt by bin/fetch_real_photos*.py)
bin/.photo_cache.json
bin/photo_manifest*.json
bin/__pycache__/
